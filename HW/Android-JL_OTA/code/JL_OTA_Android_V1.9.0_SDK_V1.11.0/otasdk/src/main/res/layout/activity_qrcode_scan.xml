<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.qr_code.QRCodeScanActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/gray_4D000000"/>

    <com.king.view.viewfinderview.ViewfinderView
        android:id="@+id/viewfinderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:vvFrameCornerColor="@color/blue_scan_partial"
        app:vvFrameCornerSize="20dp"
        app:vvFrameColor="@color/blue_398BFF"
        app:vvViewfinderStyle="classic"
        app:vvLaserStyle="line"
        app:vvLaserColor="@color/blue_scan_partial"
        app:vvFrameWidth="240dp"
        app:vvFrameHeight="240dp"
        app:vvMaskColor="@color/gray_transparent_9C272626"
        app:vvFramePaddingBottom="100dp"
        app:vvLabelText="@string/qrcode_into_box"
        app:vvLabelTextColor="@color/white"
        app:vvLabelTextSize="@dimen/text_12sp"/>

    <include
        android:id="@+id/view_top_bar"
        layout="@layout/view_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>