<Add option="-DHAS_MIDI_KEYBOARD_DECODER" />
<Add option="-DHAS_A_DECODER" />
<Add option="-DHAS_ANS_EN" />
<Add option="-DHAS_SPEED_EN" />
<Add option="-DHAS_EXT_FLASH_EN" />
<Add option="-DHAS_USB_EN=0" />
<Add option="-DHAS_SDMMC_EN" />
<Add option="-DHAS_HW_SRC_MODULE=1" />
<Add option="-DHAS_UPDATE_EN=1" />
<Add option="-DHAS_ECHO_EN" />
<Add option="-DHOWLING_EN" />
<Add option="-DHAS_NORFS_EN" />
<Add option="-DHAS_FATFS_EN" />
<Add option="-DHAS_FREEFS_EN" />
<Add option="-DSIMPLE_FATFS_ENABLE=0" />
<Add option="-DSYS_VM_EN=0" />
<Add option="-DHAS_MP3_ENCODER" />
<Add option="-DHAS_UMP3_ENCODER" />
<Add option="-DHAS_A_ENCODER" />
<Add option="-DHAS_SIMPLE_DEC_MODE" />
<Add option="-DHAS_MUSIC_MODE" />
