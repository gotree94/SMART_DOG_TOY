<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<CodeBlocks_project_file>
<FileVersion major="1" minor="6" />
<Project>
<Option title="AD23N_mbox_flash" />
<Option compiler="pi32v2_r3v2_lto_compiler" />
<Build>
<Target title="Release">
<Option output="app/post_build/sh59/sdk.elf" prefix_auto="0" extension_auto="0" />
<Option object_output="obj/Release/" />
<Option type="1" />
<Option compiler="pi32v2_r3v2_lto_compiler" />
<Compiler>
<Add option="-Wuninitialized" />
<Add option="-Wno-invalid-noreturn" />
<Add option="-fno-common" />
<Add option="-integrated-as" />
<Add option="-Oz" />
<Add option="-g" />
<Add option="-flto" />
<Add option="-fallow-pointer-null" />
<Add option="-fprefer-gnu-section" />
<Add option="-Wno-shift-negative-value" />
<Add option="-Wundef" />
<Add option="-DFPGA=0" />
<Add option="-DCPU_SH59=1" />
<Add option="-DAUDIO_ADC_EN=1" />
<Add option="-DROM_SECURE_BOOT" />
<Add option="-DSPEAKER_EN" />
